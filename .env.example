APP_PROFILE=prod
SERVER_PORT=8001
DB_URL=jdbc:postgresql://HOST:5432/DB_NAME?sslmode=require
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=postmessage
BCRYPT_STRENGTH=8

# Optional JVM flags. Leave empty by default.
# Example to auto-record 10m JFR on startup:
# JAVA_TOOL_OPTIONS=-XX:StartFlightRecording=filename=/tmp/startup.jfr,duration=10m,settings=profile
JAVA_TOOL_OPTIONS=
